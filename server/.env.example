# Dev: leave unset to use a local SQLite file (sqlite+aiosqlite:///./paninixchange.db).
# Prod (Railway): set to the managed Postgres connection string. A plain
# postgres://... or postgresql://... is auto-converted to the asyncpg driver.
# DATABASE_URL=postgresql://user:password@host:5432/paninixchange

# JWT signing secret — REQUIRED in production (use a long random value).
SECRET_KEY=your-secret-key-here

# Access token lifetime in minutes (default 1440 = 24h).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated frontend origins allowed by CORS. Defaults to the Vite dev server.
# Prod: set to the deployed frontend URL, e.g. https://paninixchange.vercel.app
# ALLOWED_ORIGINS=http://localhost:5173

# Set to 1 to log every SQL statement (verbose; dev-only). Off by default.
# SQL_ECHO=0

# Stripe — get these from the Stripe dashboard (https://dashboard.stripe.com/apikeys).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_...
SUPPORT_EMAIL=support@paninixchange.app
