# Dev: leave unset to use a local SQLite file (sqlite+aiosqlite:///./paninixchange.db).
# Prod: use Postgres, e.g.
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/paninixchange

# JWT signing secret — REQUIRED in production (use a long random value).
SECRET_KEY=your-secret-key-here

# Access token lifetime in minutes (default 1440 = 24h).
ACCESS_TOKEN_EXPIRE_MINUTES=1440
